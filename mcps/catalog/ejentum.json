{
  "id": "ejentum",
  "name": "Ejentum",
  "description": "Reasoning harness exposing four agentic tools (harness_reasoning, harness_code, harness_anti_deception, harness_memory). Each call returns a structured cognitive scaffold the agent reads before producing its user-facing answer.",
  "docsUrl": "https://ejentum.com/docs/api_reference",
  "iconBg": "#000000",
  "iconColor": "#FF0000",
  "keywords": [
    "reasoning",
    "anti-deception",
    "cognitive-scaffold",
    "agent-harness"
  ],
  "popularityRank": 200,
  "template": {
    "kind": "stdio",
    "serverName": "ejentum",
    "command": "npx",
    "args": [
      "-y",
      "ejentum-mcp"
    ],
    "envFields": [
      {
        "key": "EJENTUM_API_KEY",
        "label": "Ejentum Logic API key",
        "type": "password",
        "placeholder": "zpka_...",
        "required": true
      }
    ]
  }
}
