{
  "id": "jira",
  "name": "Jira",
  "description": "Issue tracking, sprint workflows, and engineering program management.",
  "categories": [
    "Project management",
    "Engineering"
  ],
  "appUrl": "https://www.atlassian.com/software/jira",
