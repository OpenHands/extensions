{
  "id": "asana",
  "name": "Asana",
  "description": "Task management, projects, and work tracking.",
  "categories": [
    "Project management",
    "Operations"
  ],
  "appUrl": "https://asana.com",
  "docsUrl": "https://developers.asana.com/docs/oauth",
  "notes": "Broad business adoption and straightforward OAuth app model.",
  "popularityRank": 13,
  "connectionOptions": [
    {
      "id": "oauth",
      "provider": "http",
      "auth": {
        "strategy": "oauth2",
        "oauth": {
          "authorizationUrl": "https://app.asana.com/-/oauth_authorize",
          "tokenUrl": "https://app.asana.com/-/oauth_token",
          "scopes": [
            "tasks:read"
          ]
        }
      },
      "http": {
        "apiBaseUrl": "https://app.asana.com/api/1.0",
        "openApiUrl": "https://raw.githubusercontent.com/Asana/openapi/master/defs/asana_oas.yaml"
      }
    }
  ]
}
